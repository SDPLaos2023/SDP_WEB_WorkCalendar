generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
}

// ──────────────────────────────────────────
//  (Enums defined in application code as SQL Server lacks enum support)
// ──────────────────────────────────────────

// ──────────────────────────────────────────
//  COMPANY
// ──────────────────────────────────────────

model Company {
  id        String    @id @default(uuid()) @db.NVarChar(36)
  name      String    @db.NVarChar(200)
  code      String    @unique @db.NVarChar(20)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  departments Department[]
  users       User[]

  @@index([deletedAt])
  @@map("tb_companies")
}

// ──────────────────────────────────────────
//  DEPARTMENT
// ──────────────────────────────────────────

model Department {
  id        String    @id @default(uuid()) @db.NVarChar(36)
  companyId String    @map("company_id") @db.NVarChar(36)
  name      String    @db.NVarChar(200)
  code      String    @db.NVarChar(20)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  company   Company    @relation(fields: [companyId], references: [id])
  users     User[]
  workPlans WorkPlan[]

  @@unique([companyId, code])
  @@index([companyId, deletedAt])
  @@map("tb_departments")
}

// ──────────────────────────────────────────
//  USER
// ──────────────────────────────────────────

model User {
  id               String    @id @default(uuid()) @db.NVarChar(36)
  companyId        String    @map("company_id") @db.NVarChar(36)
  departmentId     String?   @map("department_id") @db.NVarChar(36)
  role             String    @default("OFFICER") @db.NVarChar(50)
  firstName        String    @map("first_name") @db.NVarChar(100)
  lastName         String    @map("last_name") @db.NVarChar(100)
  username         String    @unique @db.NVarChar(50)
  email            String    @unique @db.NVarChar(255)
  password         String    @map("password_hash") @db.NVarChar(255)
  isActive         Boolean   @default(true) @map("is_active")
  refreshTokenHash String?   @map("refresh_token_hash") @db.NVarChar(Max)
  createdById      String?   @map("created_by") @db.NVarChar(36)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  company      Company     @relation(fields: [companyId], references: [id])
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy    User?       @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdUsers User[]      @relation("UserCreatedBy")

  managedPlans    WorkPlan[]           @relation("PlanCreatedBy")
  supervisorPlans WorkPlanSupervisor[] @relation("SupervisorPlans")
  planAssignments WorkPlanSupervisor[] @relation("PlanAssigner")
  assignedTasks   PlanTask[]           @relation("TaskAssignedTo")
  createdTasks    PlanTask[]           @relation("TaskCreatedBy")
  supervisorTasks PlanTask[]           @relation("SupervisorTasks")
  actuals         TaskActual[]
  auditLogs       AuditLog[]

  @@index([companyId, departmentId, deletedAt])
  @@index([username])
  @@map("tb_users")
}

// ──────────────────────────────────────────
//  WORK PLAN
// ──────────────────────────────────────────

model WorkPlan {
  id            String    @id @default(uuid()) @db.NVarChar(36)
  departmentId  String    @map("department_id") @db.NVarChar(36)
  createdById   String    @map("created_by") @db.NVarChar(36)
  title         String    @db.NVarChar(500)
  description   String?   @db.NVarChar(Max)
  year          Int
  planStartDate DateTime  @map("plan_start_date") @db.Date
  planEndDate   DateTime  @map("plan_end_date") @db.Date
  totalDays     Int       @map("total_days")
  status        String    @default("DRAFT") @db.NVarChar(50)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  department  Department           @relation(fields: [departmentId], references: [id])
  createdBy   User                 @relation("PlanCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tasks       PlanTask[]
  supervisors WorkPlanSupervisor[]

  @@index([departmentId, year, status, deletedAt])
  @@map("tb_work_plans")
}

// ──────────────────────────────────────────
//  WORK PLAN SUPERVISOR (Junction)
// ──────────────────────────────────────────

model WorkPlanSupervisor {
  id           String   @id @default(uuid()) @db.NVarChar(36)
  workPlanId   String   @map("work_plan_id") @db.NVarChar(36)
  supervisorId String   @map("supervisor_id") @db.NVarChar(36)
  assignedAt   DateTime @default(now()) @map("assigned_at")
  assignedById String   @map("assigned_by") @db.NVarChar(36)

  workPlan   WorkPlan @relation(fields: [workPlanId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  supervisor User     @relation("SupervisorPlans", fields: [supervisorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedBy User     @relation("PlanAssigner", fields: [assignedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([workPlanId, supervisorId])
  @@map("tb_work_plan_supervisors")
}

// ──────────────────────────────────────────
//  PLAN TASK  (Project OR Routine)
// ──────────────────────────────────────────

model PlanTask {
  id           String  @id @default(uuid()) @db.NVarChar(36)
  workPlanId   String  @map("work_plan_id") @db.NVarChar(36)
  supervisorId String? @map("supervisor_id") @db.NVarChar(36)
  assignedToId String?  @map("assigned_to") @db.NVarChar(36)
  createdById  String  @map("created_by") @db.NVarChar(36)

  taskName    String  @map("task_name") @db.NVarChar(500)
  description String? @db.NVarChar(Max)
  taskType    String  @default("PROJECT") @map("task_type") @db.NVarChar(50)
  priority    String  @default("MEDIUM") @db.NVarChar(50)
  status      String  @default("PENDING") @db.NVarChar(50)

  // ── Project task fields ──
  // used when taskType = PROJECT
  plannedStart DateTime? @map("planned_start") @db.Date
  plannedEnd   DateTime? @map("planned_end") @db.Date
  plannedDays  Int?      @map("planned_days")

  // ── Routine task fields ──
  // used when taskType = ROUTINE
  isRecurring     Boolean   @default(false) @map("is_recurring")
  recurrenceType  String?   @map("recurrence_type") @db.NVarChar(50)
  recurrenceDay   Int?      @map("recurrence_day") // 1-7 weekly / 1-31 monthly
  recurrenceStart DateTime? @map("recurrence_start") @db.Date
  recurrenceEnd   DateTime? @map("recurrence_end") @db.Date
  plannedWeeks    String?   @map("planned_weeks") @db.NVarChar(Max)

  // Materialized stats for performance
  compliancePct        Decimal @default(0.00) @map("compliance_pct") @db.Decimal(5, 2)
  currentCompletionPct Decimal @default(0.00) @map("current_completion_pct") @db.Decimal(5, 2)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  workPlan   WorkPlan     @relation(fields: [workPlanId], references: [id])
  supervisor User?        @relation("SupervisorTasks", fields: [supervisorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedTo User?        @relation("TaskAssignedTo", fields: [assignedToId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy  User         @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  actuals    TaskActual[]

  @@index([workPlanId, deletedAt])
  @@index([assignedToId, deletedAt])
  @@index([status, taskType])
  @@map("tb_plan_tasks")
}

// ──────────────────────────────────────────
//  TASK ACTUAL  (Officer updates here)
// ──────────────────────────────────────────

model TaskActual {
  id          String @id @default(uuid()) @db.NVarChar(36)
  planTaskId  String @map("plan_task_id") @db.NVarChar(36)
  updatedById String @map("updated_by") @db.NVarChar(36)

  updateType String   @map("update_type") @db.NVarChar(50)
  actualDate DateTime @map("actual_date") @db.Date

  // Project: actual start/end  |  Routine: period start/end
  actualStart DateTime? @map("actual_start") @db.Date
  actualEnd   DateTime? @map("actual_end") @db.Date
  actualDays  Int?      @map("actual_days")

  completionPct Decimal @map("completion_pct") @db.Decimal(5, 2) // 0.00 – 100.00
  status        String  @db.NVarChar(50)
  note          String? @db.NVarChar(Max)
  attachmentUrl String? @map("attachment_url") @db.NVarChar(Max)

  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  planTask  PlanTask @relation(fields: [planTaskId], references: [id])
  updatedBy User     @relation(fields: [updatedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([planTaskId, actualDate])
  @@map("tb_task_actuals")
}

// ──────────────────────────────────────────
//  AUDIT LOG
// ──────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid()) @db.NVarChar(36)
  userId    String?  @map("user_id") @db.NVarChar(36)
  action    String   @db.NVarChar(50)
  tableName String   @map("table_name") @db.NVarChar(100)
  recordId  String?  @map("record_id") @db.NVarChar(36)
  oldValues String?  @map("old_values") @db.NVarChar(Max) // JSON stored as string
  newValues String?  @map("new_values") @db.NVarChar(Max) // JSON stored as string
  ipAddress String?  @map("ip_address") @db.NVarChar(45)
  userAgent String?  @map("user_agent") @db.NVarChar(500)
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId, createdAt])
  @@index([tableName, recordId])
  @@map("tb_audit_logs")
}
