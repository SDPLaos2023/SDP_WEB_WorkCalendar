# SQL Server Connection (individual vars — used by seed.ts adapter)
DB_SERVER=your-sql-server-ip
DB_PORT=1433
DB_DATABASE=db_nuxt_template
DB_USER=sa
DB_PASSWORD=your-password

# SQL Server Connection String — used by Prisma datasource url
# Format: sqlserver://HOST:PORT;database=DB_NAME;user=USER;password=PASSWORD;trustServerCertificate=true
DATABASE_URL="sqlserver://your-sql-server-ip:1433;database=db_nuxt_template;user=sa;password=your-password;trustServerCertificate=true"

# Session Secret (must be at least 32 characters, generate a random string)
NUXT_SESSION_PASSWORD=your-random-secret-at-least-32-chars

# AES Encryption Secret Key (used for encrypting passwords in transit)
# Must be the same value used in app/utils/crypto.ts and server/utils/crypto.ts
SECRET_KEY=your-random-secret-key
